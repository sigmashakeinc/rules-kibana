# kibana_write_safety.rules
# Technology: kibana | Capability: write

rule kibana-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_kibana_PATTERN"
  MESSAGE "Blocked an unsafe pattern in kibana. Use the recommended best practices for 2025/2026."
}

rule kibana-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_kibana_API"
  MESSAGE "You are using an outdated API for kibana. Please upgrade to the newer API."
}
